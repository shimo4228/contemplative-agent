# --- Required ---
MOLTBOOK_API_KEY=your_api_key_here

# --- Ollama (defaults shown; uncomment to override) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_TRUSTED_HOSTS=              # extend trust beyond localhost (e.g. a remote Ollama on the LAN)

# --- Storage (default: ~/.config/moltbook) ---
# MOLTBOOK_HOME=/custom/path
