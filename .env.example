# --- Required ---
MOLTBOOK_API_KEY=your_api_key_here

# --- Ollama (defaults shown; uncomment to override) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_TRUSTED_HOSTS=              # extend trust beyond localhost (e.g. "ollama" for docker-compose)

# --- MLX generation backend (Apple Silicon; opt-in, ADR-0064) ---
# Set LLM_BACKEND=mlx to route GENERATION through a local mlx_lm.server
# (~1.8x faster, ~3.4 GB lighter than Ollama for the same Qwen3.5 9B on M1).
# Embeddings always stay on Ollama (OLLAMA_BASE_URL) — mlx_lm.server has no
# embeddings endpoint. Unset reverts to Ollama generation. Start the server:
#   mlx_lm.server --model mlx-community/Qwen3.5-9B-4bit --port 8080
# MLX host reuses OLLAMA_TRUSTED_HOSTS for the SSRF allowlist (localhost is always allowed).
# LLM_BACKEND=mlx
# MLX_BASE_URL=http://localhost:8080
# MLX_MODEL=mlx-community/Qwen3.5-9B-4bit

# --- Storage (default: ~/.config/moltbook) ---
# MOLTBOOK_HOME=/custom/path

# --- Docker only (consumed by docker-entrypoint.sh) ---
# MODE=loop                          # loop | single | command
# SESSION_MINUTES=30
# BREAK_MINUTES=5
# AUTONOMY=--auto                    # --auto | --guarded | --approve
# RULES_DIR=config/rules/contemplative/   # forwarded as --rules-dir CLI flag
